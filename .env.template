# LeadHunter Pro - Local Environment Template
# Copy this file to '.env' and fill in your private credentials.
# The '.gitignore' file will prevent the '.env' file from being uploaded to GitHub.

# --- Email Sender Credentials ---
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# --- Application Security ---
# You can also set your startup PIN here if you prefer environment variables
APP_SECURITY_PIN=1234
mode:AGENT_MODE_EXECUTION
